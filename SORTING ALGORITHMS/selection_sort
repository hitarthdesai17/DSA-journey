def selectionsort(arr):
    for i in range(0,len(arr)-1):
        small = i
        for j in range(i+1,len(arr)):
            if(arr[j]<arr[small]):
                small = j
        if(i!=small):
            arr[i],arr[small]=arr[small],arr[i]
    return print(arr)
arr = [2,33,42,11,23,15,76,17,0,10]
selectionsort(arr)